# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Network & Contract ──────────────────────────────────────────
RPC_URL=https://evmrpc-testnet.0g.ai
CONTRACT_ADDRESS=0x...

# Server hot wallet — must have the 'operator' role in StorageGatekeeper.
# Keep max 0.1–0.5 ETH in this wallet; top up when balance < 0.05 ETH.
OPERATOR_PRIVATE_KEY=0x...

# ── Database ─────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key   # service_role, NOT anon key

# ── AI (OpenRouter) ──────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-...
LLM_MODEL=google/gemini-2.0-flash-exp

# ── Queue (Redis / BullMQ) ───────────────────────────────────────
# When running via Docker Compose, this is overridden to redis://redis-queue:6379.
# For local dev (node directly), keep this as localhost.
REDIS_URL=redis://localhost:6379

# ── Clone / Mode-Turu Webhook ────────────────────────────────────
# HTTP port the webhook server listens on (inside the container).
WEBHOOK_PORT=3100
# Shared secret checked via `x-webhook-secret` header.
# Leave empty to disable validation (not recommended for production).
WEBHOOK_SECRET=change-me-to-a-random-string

# ── Cache ────────────────────────────────────────────────────────
# Set to false to bypass Redis cache and always fetch directly from Supabase.
# Reset cache via: POST /webhook/cache-reset (with x-webhook-secret header).
USE_CACHE=true

# ── Optional ─────────────────────────────────────────────────────
# LOG_LEVEL=info   # debug | info | warn | error

# ── 0G Storage (User Data Sync) ──────────────────────────────────
# Turbo indexer for fastest uploads on testnet.
OG_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai

# How often to run the full user-data sync cycle (default: 6 hours).
# SYNC_INTERVAL_HOURS=6

# Delay between individual user uploads to avoid RPC rate-limiting (default: 2000 ms).
# SYNC_USER_DELAY_MS=2000
